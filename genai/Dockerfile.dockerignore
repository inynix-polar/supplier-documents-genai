# Dockerfile собирается из корня репозитория; передаём только нужные ему файлы.
*
!genai/
genai/*
!genai/pyproject.toml
!genai/uv.lock
!genai/app/
!genai/app/**
!genai/eval/
!genai/eval/**
!genai/tests/
!genai/tests/**
!scripts/
!scripts/**

# Повторно исключаем локальные кеши внутри разрешённых директорий.
**/.mypy_cache/
**/.pytest_cache/
**/.ruff_cache/
**/.venv/
**/__pycache__/
**/*.py[cod]
**/.DS_Store
